{
  "name": "Organising Committee Sheet",
  "description": "Details of the organizing committee",
  "icon": "👥",
  "fields": [
    {
      "label": "Event Name",
      "name": "event_name",
      "type": "text",
      "required": true,
      "placeholder": "e.g. Aarohi Women's Day Celebration"
    },
    {
      "label": "Date",
      "name": "date",
      "type": "date",
      "required": true
    },
    {
      "label": "Time",
      "name": "time",
      "type": "time",
      "required": true
    },
    {
      "label": "Mode of the Event",
      "name": "mode",
      "type": "select",
      "required": true,
      "options": [
        "Online",
        "Offline",
        "Hybrid"
      ]
    },
    {
      "label": "Faculty Coordinator",
      "name": "faculty_coordinators",
      "type": "table",
      "columns": [
        {
          "name": "name",
          "label": "Name of the Faculty"
        },
        {
          "name": "school",
          "label": "Name of the School"
        }
      ]
    },
    {
      "label": "Student Coordinator",
      "name": "student_coordinators",
      "type": "table",
      "columns": [
        {
          "name": "name",
          "label": "Name of the Student"
        },
        {
          "name": "year_sem",
          "label": "Year/Sem"
        },
        {
          "name": "branch",
          "label": "Branch"
        }
      ]
    },
    {
      "label": "Organising Team",
      "name": "organising_team",
      "type": "table",
      "columns": [
        {
          "name": "name",
          "label": "Name of the Student"
        },
        {
          "name": "year_sem",
          "label": "Year/Sem"
        },
        {
          "name": "branch",
          "label": "Branch"
        }
      ]
    },
    {
      "label": "Include Resource Person",
      "name": "show_resource_persons",
      "type": "checkbox"
    },
    {
      "label": "Resource Person",
      "name": "resource_persons",
      "type": "table",
      "columns": [
        {
          "name": "name",
          "label": "Name"
        },
        {
          "name": "type",
          "label": "Internal / External"
        },
        {
          "name": "organization",
          "label": "Name of the School/Organization"
        }
      ]
    }
  ]
}