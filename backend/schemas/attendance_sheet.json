{
  "name": "Attendance Sheet",
  "description": "Event participant attendance list",
  "icon": "📋",
  "fields": [
    {"label": "Event Name", "name": "event_name", "type": "text", "required": true, "placeholder": "e.g. Workshop on AI"},
    {"label": "Date", "name": "date", "type": "date", "required": true},
    {"label": "Time", "name": "time", "type": "time"},
    {"label": "Mode of the Event", "name": "mode", "type": "select", "options": ["Online", "Offline", "Hybrid"]},
    {
      "label": "Participants",
      "name": "participants",
      "type": "table",
      "columns": [
        {"name": "name", "label": "Name of the Student"},
        {"name": "school", "label": "Name of the School"},
        {"name": "department", "label": "Department"},
        {"name": "attendance", "label": "Attendance"}
      ]
    }
  ]
}
