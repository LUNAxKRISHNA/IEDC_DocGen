{
  "name": "Approval Request Letter",
  "description": "Request for Permission to organise an event",
  "fields": [
    {
      "label": "Ref No",
      "name": "ref_no",
      "type": "text",
      "required": true,
      "placeholder": "e.g. CVVIEDC/SE/01"
    },
    {
      "label": "Date",
      "name": "date",
      "type": "date",
      "required": true
    },
    {
      "label": "Event Name",
      "name": "event_name",
      "type": "text",
      "required": true,
      "placeholder": "e.g. Aarohi 2025 - Women's Day Celebration"
    },
    {
      "label": "Body Paragraphs",
      "name": "body_text",
      "type": "textarea",
      "required": true,
      "placeholder": "Enter paragraphs separated by newlines"
    },
    {
      "label": "Sender Name",
      "name": "sender_name",
      "type": "text",
      "required": true
    },
    {
      "label": "Sender Designation",
      "name": "sender_designation",
      "type": "text",
      "required": true,
      "placeholder": "e.g. Student Lead"
    },
    {
      "label": "Sender Department",
      "name": "sender_department",
      "type": "text",
      "required": true,
      "placeholder": "e.g. CVV IEDC"
    }
  ]
}